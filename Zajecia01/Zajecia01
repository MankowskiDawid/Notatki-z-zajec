przelicz_walute = function(kwota, kurs = 4.32) { 
wynik = kwota * kurs 
return(wynik) 
}


zad 6 B
ocena_kredytowa = function(dochod, zadluzenie) { 
udzial = zadluzenie / dochod 
if (udzial < 0.30) { 
return("KREDYT PRZYZNANY") 
} 
else if (udzial <= 0.50) { 
return("WYMAGA WERYFIKACJI") 
} 
else { 
return("KREDYT ODRZUCONY") 
} 
}



